# =====================================================
# AI Smart Attendance System - Environment Configuration
# =====================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
#

# =====================================================
# Gmail SMTP Configuration (Email Notifications)
# =====================================================
# For Gmail users with 2-Step Verification:
# 1. Visit: https://myaccount.google.com/apppasswords
# 2. Select "Mail" + "Windows Computer"
# 3. Copy the 16-character password below

EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_16_character_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# For non-Gmail SMTP servers, update EMAIL_HOST and EMAIL_PORT
# Example (Gmail): EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587
# Example (Outlook): EMAIL_HOST=smtp-mail.outlook.com, EMAIL_PORT=587
# Example (Yahoo): EMAIL_HOST=smtp.mail.yahoo.com, EMAIL_PORT=587


# =====================================================
# Flask Configuration
# =====================================================
# Generate a random secret key:
# python -c "import secrets; print(secrets.token_hex(16))"

SECRET_KEY=replace_with_a_random_secret_key_here


# =====================================================
# Face Recognition Tuning
# =====================================================
# Recognition threshold (0.0 - 1.0)
# Lower value = stricter matching (fewer false positives)
# Higher value = more lenient matching (fewer false negatives)
# Default: 0.52
# Recommended range: 0.4 - 0.6

RECOG_THRESHOLD=0.52


# =====================================================
# Optional: Advanced Configuration
# =====================================================

# Database path (default: project root)
# DATABASE_PATH=./attendance.db

# Model path (default: models/face_data.pkl)
# MODEL_PATH=./models/face_data.pkl

# Dataset path (default: dataset/)
# DATASET_PATH=./dataset

# Debug mode (set to False in production)
# DEBUG=False
